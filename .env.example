# Optional: point frontend directly to Umbraco instead of Vite proxy
# VITE_UMBRACO_BASE_URL=https://localhost:7210

# Optional: override full endpoint if you need a custom query
# VITE_UMBRACO_PRODUCTS_ENDPOINT=/umbraco/delivery/api/v2/content?fetch=descendants:*&filter=contentType:product&take=100

# Content type alias for products in Umbraco
VITE_UMBRACO_PRODUCT_ALIAS=product

# Optional headers for Delivery API queries
# VITE_UMBRACO_START_ITEM=
# VITE_UMBRACO_DELIVERY_API_KEY=
# VITE_UMBRACO_ACCEPT_LANGUAGE=sv-SE
# VITE_UMBRACO_ACCEPT_SEGMENT=
